<div class="modal fade" id="<%= modalId %>" tabindex="-1"><div class="modal-dialog"><form class="modal-content" action="/admin/announcements/save" method="post">
  <div class="modal-header"><h5 class="modal-title"><%= item ? "Edit Announcement" : "Add Announcement" %></h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
  <div class="modal-body">
    <% if (item) { %><input type="hidden" name="id" value="<%= item.id %>"><% } %>
    <label class="form-label">Date</label><input class="form-control mb-3" type="date" name="announcement_date" value="<%= item ? (item.announcement_date.toISOString ? item.announcement_date.toISOString().slice(0,10) : item.announcement_date) : new Date().toISOString().slice(0,10) %>" required>
    <label class="form-label">Title</label><input class="form-control mb-3" name="title" value="<%= item ? item.title : "" %>" required>
    <label class="form-label">Body</label><textarea class="form-control mb-3" name="body" required><%= item ? item.body : "" %></textarea>
    <div class="form-check"><input class="form-check-input" type="checkbox" name="is_active" <%= !item || item.is_active ? "checked" : "" %>><label class="form-check-label">Active</label></div>
  </div>
  <div class="modal-footer"><button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button><button class="btn btn-primary">Save</button></div>
</form></div></div>
