<%- include("../partials/head", { title }) %>
<div class="admin-layout"><%- include("../partials/admin-sidebar") %>
  <main class="admin-main p-4">
    <div class="d-flex justify-content-between align-items-center mb-4"><h1 class="h3 fw-bold mb-0">Manage Schedules</h1><button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#scheduleModal"><i class="bi bi-plus-lg me-2"></i>Add Schedule</button></div>
    <div class="card border-0 shadow-sm"><div class="table-responsive"><table class="table table-hover align-middle mb-0">
      <thead><tr><th>Day</th><th>Time</th><th>Subject</th><th>Teacher</th><th>Room</th><th class="text-end">Actions</th></tr></thead>
      <tbody><% schedules.forEach((item) => { %><tr><td><span class="badge text-bg-primary"><%= item.day_name %></span></td><td><%= item.start_time %> - <%= item.end_time %></td><td><strong><%= item.subject %></strong></td><td><%= item.teacher %></td><td><%= item.room %></td><td class="text-end"><button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editSchedule<%= item.id %>"><i class="bi bi-pencil"></i></button> <form action="/admin/schedules/<%= item.id %>/delete" method="post" class="d-inline"><button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button></form></td></tr><% }) %></tbody>
    </table></div></div>
    <%- include("schedule-form", { modalId: "scheduleModal", item: null }) %>
    <% schedules.forEach((item) => { %><%- include("schedule-form", { modalId: `editSchedule${item.id}`, item }) %><% }) %>
  </main>
</div><%- include("../partials/scripts") %>
