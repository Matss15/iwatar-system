<%- include("../partials/head", { title }) %>
<div class="admin-layout"><%- include("../partials/admin-sidebar") %>
  <main class="admin-main p-4">
    <div class="d-flex justify-content-between align-items-center mb-4"><h1 class="h3 fw-bold mb-0">Attendance / Scan Logs</h1><span class="badge text-bg-light border">Fingerprint and thermal results</span></div>
    <% if (reportMessage) { %><div class="alert alert-success"><%= reportMessage %></div><% } %>
    <% if (reportError) { %><div class="alert alert-danger"><%= reportError %></div><% } %>
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white fw-bold"><i class="bi bi-envelope-paper me-2 text-primary"></i>Email PDF Reports</div>
      <div class="card-body">
        <form action="/admin/logs/report-settings" method="post" class="row g-3 align-items-end mb-3">
          <div class="col-lg-7">
            <label class="form-label">Teacher email recipients</label>
            <textarea class="form-control" name="recipients" rows="3" placeholder="teacher1@gmail.com, teacher2@gmail.com"><%= reportSettings.recipients || "" %></textarea>
          </div>
          <div class="col-sm-6 col-lg-2">
            <label class="form-label">Auto send time</label>
            <input class="form-control" type="time" name="send_time" value="<%= reportSettings.send_time || "17:00" %>">
          </div>
          <div class="col-sm-6 col-lg-3">
            <div class="form-check mb-3">
              <input class="form-check-input" type="checkbox" id="autoEnabled" name="auto_enabled" <%= reportSettings.auto_enabled ? "checked" : "" %>>
              <label class="form-check-label" for="autoEnabled">Send automatically every day</label>
            </div>
            <button class="btn btn-outline-primary w-100"><i class="bi bi-save me-2"></i>Save Settings</button>
          </div>
        </form>
        <form action="/admin/logs/send-report" method="post" class="row g-3 align-items-end">
          <div class="col-md-4 col-lg-3">
            <label class="form-label">Report date</label>
            <input class="form-control" type="date" name="report_date" value="<%= reportDate %>">
          </div>
          <div class="col-md-8 col-lg-6">
            <label class="form-label">Send to</label>
            <input class="form-control" name="recipients" value="<%= reportSettings.recipients || "" %>" placeholder="Leave as saved recipients">
          </div>
          <div class="col-lg-3">
            <button class="btn btn-primary w-100"><i class="bi bi-file-earmark-pdf me-2"></i>Send PDF Report</button>
          </div>
        </form>
      </div>
    </div>
    <div class="card border-0 shadow-sm"><div class="table-responsive"><table class="table table-hover align-middle mb-0">
      <thead><tr><th>Student</th><th>LRN</th><th>Type</th><th>Temperature</th><th>Status</th><th>Message</th><th>Time</th></tr></thead>
      <tbody><% logs.forEach((log) => { %><tr><td><strong><%= log.first_name || "Unknown" %> <%= log.last_name || "" %></strong><br><small class="text-secondary"><%= log.section || "" %></small></td><td><%= log.lrn || "-" %></td><td><span class="badge text-bg-light border"><%= log.scan_type %></span></td><td><%= log.temperature_c || "-" %></td><td><span class="badge <%= log.status === 'flagged' ? 'text-bg-danger' : 'text-bg-success' %>"><%= log.status %></span></td><td><%= log.message || "" %></td><td><%= log.scanned_at.toLocaleString ? log.scanned_at.toLocaleString() : log.scanned_at %></td></tr><% }) %></tbody>
    </table></div></div>
  </main>
</div><%- include("../partials/scripts") %>
