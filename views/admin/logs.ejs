<%- include("../partials/head", { title }) %>
<div class="admin-layout"><%- include("../partials/admin-sidebar") %>
  <main class="admin-main p-4">
    <div class="d-flex justify-content-between align-items-center mb-4"><h1 class="h3 fw-bold mb-0">Attendance / Scan Logs</h1><span class="badge text-bg-light border">Fingerprint and thermal results</span></div>
    <div class="card border-0 shadow-sm"><div class="table-responsive"><table class="table table-hover align-middle mb-0">
      <thead><tr><th>Student</th><th>LRN</th><th>Type</th><th>Temperature</th><th>Status</th><th>Message</th><th>Time</th></tr></thead>
      <tbody><% logs.forEach((log) => { %><tr><td><strong><%= log.first_name || "Unknown" %> <%= log.last_name || "" %></strong><br><small class="text-secondary"><%= log.section || "" %></small></td><td><%= log.lrn || "-" %></td><td><span class="badge text-bg-light border"><%= log.scan_type %></span></td><td><%= log.temperature_c || "-" %></td><td><span class="badge <%= log.status === 'flagged' ? 'text-bg-danger' : 'text-bg-success' %>"><%= log.status %></span></td><td><%= log.message || "" %></td><td><%= log.scanned_at.toLocaleString ? log.scanned_at.toLocaleString() : log.scanned_at %></td></tr><% }) %></tbody>
    </table></div></div>
  </main>
</div><%- include("../partials/scripts") %>
