<div class="modal fade" id="<%= modalId %>" tabindex="-1"><div class="modal-dialog"><form class="modal-content" action="/admin/schedules/save" method="post">
  <div class="modal-header"><h5 class="modal-title"><%= item ? "Edit Schedule" : "Add Schedule" %></h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
  <div class="modal-body row g-3">
    <% if (item) { %><input type="hidden" name="id" value="<%= item.id %>"><% } %>
    <div class="col-md-6"><label class="form-label">Day</label><select class="form-select" name="day_name"><% ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"].forEach((day) => { %><option <%= item && item.day_name === day ? "selected" : "" %>><%= day %></option><% }) %></select></div>
    <div class="col-md-3"><label class="form-label">Start</label><input class="form-control" type="time" name="start_time" value="<%= item ? item.start_time : "" %>" required></div>
    <div class="col-md-3"><label class="form-label">End</label><input class="form-control" type="time" name="end_time" value="<%= item ? item.end_time : "" %>" required></div>
    <div class="col-md-6"><label class="form-label">Subject</label><input class="form-control" name="subject" value="<%= item ? item.subject : "" %>" required></div>
    <div class="col-md-6"><label class="form-label">Teacher</label><input class="form-control" name="teacher" value="<%= item ? item.teacher : "" %>"></div>
    <div class="col-12"><label class="form-label">Room</label><input class="form-control" name="room" value="<%= item ? item.room : "" %>"></div>
  </div>
  <div class="modal-footer"><button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button><button class="btn btn-primary">Save</button></div>
</form></div></div>
