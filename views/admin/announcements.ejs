<%- include("../partials/head", { title }) %>
<div class="admin-layout"><%- include("../partials/admin-sidebar") %>
  <main class="admin-main p-4">
    <div class="d-flex justify-content-between align-items-center mb-4"><h1 class="h3 fw-bold mb-0">Manage Announcements</h1><button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#announcementModal"><i class="bi bi-plus-lg me-2"></i>Add Announcement</button></div>
    <div class="card border-0 shadow-sm"><div class="table-responsive"><table class="table table-hover align-middle mb-0">
      <thead><tr><th>Date</th><th>Title</th><th>Body</th><th>Status</th><th class="text-end">Actions</th></tr></thead>
      <tbody><% announcements.forEach((item) => { %><tr><td><%= item.announcement_date.toISOString ? item.announcement_date.toISOString().slice(0,10) : item.announcement_date %></td><td><strong><%= item.title %></strong></td><td><%= item.body %></td><td><span class="badge <%= item.is_active ? 'text-bg-success' : 'text-bg-secondary' %>"><%= item.is_active ? 'Active' : 'Hidden' %></span></td><td class="text-end"><button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editAnnouncement<%= item.id %>"><i class="bi bi-pencil"></i></button> <form action="/admin/announcements/<%= item.id %>/delete" method="post" class="d-inline"><button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button></form></td></tr><% }) %></tbody>
    </table></div></div>
    <%- include("announcement-form", { modalId: "announcementModal", item: null }) %>
    <% announcements.forEach((item) => { %><%- include("announcement-form", { modalId: `editAnnouncement${item.id}`, item }) %><% }) %>
  </main>
</div><%- include("../partials/scripts") %>
