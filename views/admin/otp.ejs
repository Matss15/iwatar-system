<%- include("../partials/head", { title }) %>
<main class="login-page d-flex align-items-center justify-content-center min-vh-100">
  <div class="card login-card border-0 shadow">
    <div class="card-body p-4">
      <div class="text-center mb-4">
        <img src="/images/iwatar-logo.png" class="login-logo mb-3" alt="IWATAR logo">
        <h1 class="h4 fw-bold">Google Authenticator</h1>
        <p class="text-secondary mb-0">Enter the 6-digit code from your authenticator app.</p>
      </div>

      <% if (setup) { %>
        <div class="alert alert-info">
          Open Google Authenticator, add a setup key, then enter the generated code below.
        </div>
        <label class="form-label">Setup Key</label>
        <div class="otp-secret mb-3"><%= secret %></div>
        <input class="form-control mb-3" value="<%= otpAuthUri %>" readonly>
      <% } %>

      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <form action="/admin/login/otp" method="post">
        <label class="form-label">Authenticator Code</label>
        <input class="form-control otp-input mb-3" name="otp" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" autocomplete="one-time-code" required autofocus>
        <button class="btn btn-primary w-100"><i class="bi bi-shield-lock me-2"></i>Verify OTP</button>
      </form>

      <div class="text-center mt-3">
        <a href="/admin/login" class="text-decoration-none">Back to login</a>
      </div>
    </div>
  </div>
</main>
<%- include("../partials/scripts") %>
